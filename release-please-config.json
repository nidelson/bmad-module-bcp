{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "include-component-in-tag": false,
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "path": "skills/bmad-bcp-setup/assets/module.yaml",
          "type": "yaml",
          "jsonpath": "$.module_version"
        },
        {
          "path": "module.yaml",
          "type": "yaml",
          "jsonpath": "$.module_version"
        },
        {
          "path": ".claude-plugin/marketplace.json",
          "type": "json",
          "jsonpath": "$.plugins[0].version"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Funcionalidades" },
        { "type": "fix", "section": "Correções" },
        { "type": "perf", "section": "Melhorias de Performance" },
        { "type": "refactor", "section": "Refatoração" },
        { "type": "docs", "section": "Documentação" },
        { "type": "build", "section": "Build" },
        { "type": "ci", "section": "Integração Contínua" },
        { "type": "test", "section": "Testes" },
        { "type": "style", "section": "Estilo" },
        { "type": "chore", "section": "Manutenção" },
        { "type": "revert", "section": "Reversões" }
      ]
    }
  }
}
